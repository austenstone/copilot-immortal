{
	"hooks": {
		"SessionStart": [
			{
				"type": "command",
				"command": ".github/hooks/context.sh"
			}
		],
		"Stop": [
			{
				"type": "command",
				"command": ".github/hooks/heartbeat.sh"
			}
		],
		"PreCompact": [
			{
				"type": "command",
				"command": ".github/hooks/persist.sh"
			}
		],
		"PreToolUse": [
			{
				"type": "command",
				"command": ".github/hooks/guard.sh"
			}
		]
	}
}
