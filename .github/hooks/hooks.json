{
	"hooks": {
		"Stop": [
			{
				"type": "command",
				"command": "./scripts/heartbeat.sh",
				"env": {
					"COPILOT_HEARTBEAT_INTERVAL": "5"
				},
				"timeout": 600
			}
		],
		"SessionStart": [
			{
				"type": "command",
				"command": "./scripts/context.sh"
			}
		],
		"PreCompact": [
			{
				"type": "command",
				"command": "./scripts/persist.sh"
			}
		],
		"PreToolUse": [
			{
				"type": "command",
				"command": "./scripts/guard.sh"
			}
		]
	}
}
