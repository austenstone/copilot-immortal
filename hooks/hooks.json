{
	"version": 1,
	"hooks": {
		"Stop": [
			{
				"type": "command",
				"bash": "${CLAUDE_PLUGIN_ROOT}/heartbeat.sh",
				"cwd": ".",
				"env": {
					"COPILOT_HEARTBEAT_INTERVAL": "120"
				},
				"timeoutSec": 30
			}
		],
		"SessionStart": [
			{
				"type": "command",
				"bash": "${CLAUDE_PLUGIN_ROOT}/context.sh",
				"cwd": ".",
				"timeoutSec": 10
			}
		],
		"PreCompact": [
			{
				"type": "command",
				"bash": "${CLAUDE_PLUGIN_ROOT}/persist.sh",
				"cwd": ".",
				"timeoutSec": 10
			}
		],
		"PreToolUse": [
			{
				"type": "command",
				"bash": "${CLAUDE_PLUGIN_ROOT}/guard.sh",
				"cwd": ".",
				"timeoutSec": 10
			}
		]
	}
}
