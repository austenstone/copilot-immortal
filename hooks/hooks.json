{
	"version": 1,
	"hooks": {
		"Stop": [
			{
				"type": "command",
				"bash": "${CLAUDE_PLUGIN_ROOT}/hooks/heartbeat.sh",
				"env": {
					"COPILOT_HEARTBEAT_INTERVAL": "120"
				},
				"timeoutSec": 30
			}
		],
		"SessionStart": [
			{
				"type": "command",
				"bash": "${CLAUDE_PLUGIN_ROOT}/hooks/context.sh",
				"timeoutSec": 10
			}
		],
		"PreCompact": [
			{
				"type": "command",
				"bash": "${CLAUDE_PLUGIN_ROOT}/hooks/persist.sh",
				"timeoutSec": 10
			}
		],
		"PreToolUse": [
			{
				"type": "command",
				"bash": "${CLAUDE_PLUGIN_ROOT}/hooks/guard.sh",
				"timeoutSec": 10
			}
		]
	}
}
