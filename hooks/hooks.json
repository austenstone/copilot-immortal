{
	"version": 1,
	"hooks": {
		"Stop": [
			{
				"type": "command",
				"bash": "hooks/heartbeat.sh",
				"cwd": "${CLAUDE_PLUGIN_ROOT}",
				"env": {
					"COPILOT_HEARTBEAT_INTERVAL": "120"
				},
				"timeoutSec": 30
			}
		],
		"SessionStart": [
			{
				"type": "command",
				"bash": "hooks/context.sh",
				"cwd": "${CLAUDE_PLUGIN_ROOT}",
				"timeoutSec": 10
			}
		],
		"PreCompact": [
			{
				"type": "command",
				"bash": "hooks/persist.sh",
				"cwd": "${CLAUDE_PLUGIN_ROOT}",
				"timeoutSec": 10
			}
		],
		"PreToolUse": [
			{
				"type": "command",
				"bash": "hooks/guard.sh",
				"cwd": "${CLAUDE_PLUGIN_ROOT}",
				"timeoutSec": 10
			}
		]
	}
}
