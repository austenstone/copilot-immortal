{
	"version": 1,
	"hooks": {
		"Stop": [
			{
				"type": "command",
				"command": "./hooks/heartbeat.sh",
				"env": {
					"COPILOT_HEARTBEAT_INTERVAL": "120"
				},
				"timeout": 30
			}
		],
		"SessionStart": [
			{
				"type": "command",
				"command": "./hooks/context.sh",
				"timeout": 10
			}
		],
		"PreCompact": [
			{
				"type": "command",
				"command": "./hooks/persist.sh",
				"timeout": 10
			}
		],
		"PreToolUse": [
			{
				"type": "command",
				"command": "./hooks/guard.sh",
				"timeout": 10
			}
		]
	}
}
